@app.command()
def version():
    panel = Panel(
        f"[bold cyan]hyphenctl[/bold cyan] v{VERSION}",
        title="[cyan]Hyphen CLI[/cyan]",
        expand=False,
    )
    console.print(panel)


@app.command()
def install(package: str):
    started_time = dt.now()
    package = package.replace(".hmp", "")
    db_path = os.path.join(hyphenctl_path, "database.json")

    if not os.path.exists(db_path):
        console.print(
            Panel(
                f"[bold red]Error:[/bold red] database.json not found at {db_path}",
                title="[cyan]Hyphen CLI[/cyan]",
                expand=False,
            )
        )
        return

    with open(db_path) as f:
        data = json.load(f)

    found = False
    for base_url in data["databases"]:
        link = base_url.rstrip("/") + "/" + package + ".hmp"
        sha256_link = link + ".sha256"

        try:
            resp = requests.head(link, allow_redirects=True, timeout=5)
        except requests.RequestException:
            continue

        if resp.status_code == 200:
            found = True
            console.print(
                Panel(
                    f"[bold cyan]Found:[/bold cyan] {package}\nStarting installation...",
                    title="[cyan]Hyphen CLI[/cyan]",
                    expand=False,
                )
            )

            try:
                # download_module artık hmp_path de döndürüyor
                temp_dir, meta_path, hmp_path = download_module(link, package + ".hmp")

                # --- SHA256 İndirme ve Doğrulama ---
                sha256_path = os.path.join(temp_dir, package + ".hmp.sha256")
                try:
                    sha_resp = requests.get(sha256_link, timeout=5)
                    sha_resp.raise_for_status()
                    with open(sha256_path, "wb") as sf:
                        sf.write(sha_resp.content)

                    # .sha256 dosyasının içeriğini oku (Format genelde: "hash  dosyaadi.hmp" şeklindedir)
                    with open(sha256_path, "r") as sf:
                        sha_content = (
                            sf.read().strip().split()[0]
                        )  # Sadece hash kısmını al

                    # İndirilen .hmp dosyasının SHA256 değerini hesapla
                    sha256_hash = hashlib.sha256()
                    with open(hmp_path, "rb") as f:
                        for byte_block in iter(lambda: f.read(4096), b""):
                            sha256_hash.update(byte_block)
                    actual_hash = sha256_hash.hexdigest()

                    # Karşılaştırma
                    if actual_hash != sha_content:
                        shutil.rmtree(temp_dir)
                        console.print(
                            Panel(
                                f"[bold red]SHA256 Verification Failed![/bold red]\nExpected: {sha_content}\nActual: {actual_hash}\nThe file may be corrupted or tampered with.",
                                title="[cyan]Hyphen CLI[/cyan]",
                                expand=False,
                            )
                        )
                        return  # Doğrulama başarısız, işlemi iptal et

                    console.print(
                        Panel(
                            f"[bold green]SHA256 Verification Successful.[/bold green]",
                            title="[cyan]Hyphen CLI[/cyan]",
                            expand=False,
                        )
                    )

                except requests.exceptions.RequestException:
                    # SHA256 dosyası bulunamazsa uyarı ver ama kuruma devam et (isteğe bağlı dilenirse return eklenir)
                    sha256_path = None
                    console.print(
                        Panel(
                            f"[bold yellow]Warning:[/bold yellow] .sha256 file not found at {sha256_link}. Skipping verification.",
                            title="[cyan]Hyphen CLI[/cyan]",
                            expand=False,
                        )
                    )

                # --- Meta Okuma ---
                with open(meta_path) as m:
                    info = yaml.safe_load(m)

                name = f"[bold cyan]Name         [/bold cyan]{info.get('name', 'N/A')}"
                desc = f"[bold cyan]Description  [/bold cyan]{info.get('description', 'N/A')}"
                vers = (
                    f"[bold cyan]Version      [/bold cyan]{info.get('version', 'N/A')}"
                )

                auth = ["[bold cyan]Authors       [/bold cyan]"]
                for a in info.get("authors", []):
                    auth.append(f"             {a.get('name', 'Unknown')}")

                panel = Panel(
                    f"{name}\n{desc}\n{vers}\n" + "\n".join(auth),
                    title="[cyan]Hyphen CLI - Module Information[/cyan]",
                    expand=False,
                )
                console.print(panel)

                # --- Dosya Taşıma İşlemleri ---
                if platform.system() == "Windows":
                    dest_dir = f"{hyphenctl_path}\\lib\\{info.get('name')}"

                    # Tek bir powershell komutunda tüm dosyaları taşıyoruz
                    move_commands = [
                        f"New-Item -ItemType Directory -Force -Path '{dest_dir}';",
                        f"Move-Item -Force '{meta_path}' '{dest_dir}\\{meta_path.split(chr(92))[-1]}';",
                        f"Move-Item -Force '{os.path.join(temp_dir, info.get('file'))}' '{dest_dir}\\{info.get('file')}';",
                    ]
                    if sha256_path:
                        move_commands.append(
                            f"Move-Item -Force '{sha256_path}' '{dest_dir}\\{sha256_path.split(chr(92))[-1]}';"
                        )

                    ps_script = " ".join(move_commands)

                    subprocess.run(
                        [
                            "powershell",
                            "-Command",
                            f"Start-Process powershell -Verb RunAs -ArgumentList '-Command {ps_script}'",
                        ]
                    )
                else:
                    # Linux/Unix sudo/doas kontrolü
                    has_sudo = False
                    has_doas = False
                    try:
                        resultsudo = subprocess.run(
                            ["sudo", "--version"],
                            stdout=subprocess.DEVNULL,
                            stderr=subprocess.DEVNULL,
                        )
                        if resultsudo.returncode == 0:
                            has_sudo = True
                    except Exception:
                        pass
                    try:
                        resultdoas = subprocess.run(
                            ["doas", "--version"],
                            stdout=subprocess.DEVNULL,
                            stderr=subprocess.DEVNULL,
                        )
                        if resultdoas.returncode == 0:
                            has_doas = True
                    except Exception:
                        pass

                    priv_escalation_tool = None
                    if has_sudo:
                        priv_escalation_tool = "sudo"
                    elif has_doas:
                        priv_escalation_tool = "doas"

                    lib_dir = f"{hyphenctl_path}/lib/{package}"

                    if priv_escalation_tool:
                        subprocess.run([priv_escalation_tool, "mkdir", "-pv", lib_dir])
                        subprocess.run(
                            [
                                priv_escalation_tool,
                                "mv",
                                meta_path,
                                f"{lib_dir}/{meta_path.split('/')[-1]}",
                            ]
                        )
                        subprocess.run(
                            [
                                priv_escalation_tool,
                                "mv",
                                os.path.join(temp_dir, info.get("file")),
                                f"{lib_dir}/{info.get('file')}",
                            ]
                        )
                        if sha256_path:
                            subprocess.run(
                                [
                                    priv_escalation_tool,
                                    "mv",
                                    sha256_path,
                                    f"{lib_dir}/{sha256_path.split('/')[-1]}",
                                ]
                            )
                    else:
                        try:
                            subprocess.run(["mkdir", "-pv", lib_dir])
                            subprocess.run(
                                [
                                    "mv",
                                    meta_path,
                                    f"{lib_dir}/{meta_path.split('/')[-1]}",
                                ]
                            )
                            subprocess.run(
                                [
                                    "mv",
                                    os.path.join(temp_dir, info.get("file")),
                                    f"{lib_dir}/{info.get('file')}",
                                ]
                            )
                            if sha256_path:
                                subprocess.run(
                                    [
                                        "mv",
                                        sha256_path,
                                        f"{lib_dir}/{sha256_path.split('/')[-1]}",
                                    ]
                                )
                        except Exception as e:
                            console.print(
                                Panel(
                                    f"[bold red]ERROR[/bold red] Your system does not have a privilege escalation tool.\nPlease install [bold yellow]sudo, doas[/bold yellow] or similar tools and try again.",
                                    title="[cyan]Hyphen CLI[/cyan]",
                                    expand=False,
                                )
                            )
                            shutil.rmtree(temp_dir)
                            return

                # Geçici dizini temizle
                shutil.rmtree(temp_dir)

                # Süre hesaplama (Windows ve Linux başarılı kurulumları için burada olmalı)
                time_passed = dt.now() - started_time
                seconds = time_passed.total_seconds()
                console.print(
                    Panel(
                        f"[bold cyan]Installed:[/bold cyan] {package}\nCompleted in {int(seconds // 60)}m {int(seconds % 60)}s",
                        title="[cyan]Hyphen CLI[/cyan]",
                        expand=False,
                    )
                )
                break  # Kurulum başarılı, döngüyü kır

            except Exception as e:
                console.print(
                    Panel(
                        f"[bold red]An error occurred during installation[/bold red]\n{e}",
                        title="[cyan]Hyphen CLI[/cyan]",
                        expand=False,
                    )
                )
                if "temp_dir" in locals() and os.path.exists(temp_dir):
                    shutil.rmtree(temp_dir)
                break

    if not found:
        console.print(
            Panel(
                f"[bold red]Package not found:[/bold red] {package}",
                title="[cyan]Hyphen CLI[/cyan]",
                expand=False,
            )
        )

@app.command()
def update(package: str):
    started_time = dt.now()
    lib_dir = os.path.join(hyphenctl_path, "lib", package)
    meta_path = os.path.join(lib_dir, "meta.hyphen")

    if not os.path.exists(meta_path):
        console.print(
            Panel(
                f"[bold red]Error:[/bold red] Package '{package}' is not installed.",
                title="[cyan]Hyphen CLI[/cyan]",
                expand=False,
            )
        )
        return

    # Mevcut kurulu sürümü oku
    with open(meta_path) as m:
        old_info = yaml.safe_load(m)
    old_version = old_info.get("version", "0.0.0")

    db_path = os.path.join(hyphenctl_path, "database.json")
    if not os.path.exists(db_path):
        console.print(
            Panel(
                f"[bold red]Error:[/bold red] database.json not found.",
                title="[cyan]Hyphen CLI[/cyan]",
                expand=False,
            )
        )
        return

    with open(db_path) as f:
        data = json.load(f)

    found = False
    for base_url in data["databases"]:
        link = base_url.rstrip("/") + "/" + package + ".hmp"
        sha256_link = link + ".sha256"

        try:
            resp = requests.head(link, allow_redirects=True, timeout=5)
        except requests.RequestException:
            continue

        if resp.status_code == 200:
            found = True
            console.print(
                Panel(
                    f"[bold cyan]Checking for updates...[/bold cyan]",
                    title="[cyan]Hyphen CLI[/cyan]",
                    expand=False,
                )
            )

            try:
                temp_dir, new_meta_path, new_hmp_path = download_module(
                    link, package + ".hmp"
                )

                # Yeni indirilenin SHA256 kontrolünü yap
                sha256_path = os.path.join(temp_dir, package + ".hmp.sha256")
                try:
                    sha_resp = requests.get(sha256_link, timeout=5)
                    sha_resp.raise_for_status()
                    with open(sha256_path, "wb") as sf:
                        sf.write(sha_resp.content)

                    sha256_hash = hashlib.sha256()
                    with open(new_hmp_path, "rb") as f:
                        for byte_block in iter(lambda: f.read(4096), b""):
                            sha256_hash.update(byte_block)
                    actual_hash = sha256_hash.hexdigest()

                    with open(sha256_path, "r") as sf:
                        expected_hash = sf.read().strip().split()[0]

                    if actual_hash != expected_hash:
                        shutil.rmtree(temp_dir)
                        console.print(
                            Panel(
                                f"[bold red]Downloaded file SHA256 mismatch! Aborting update.[/bold red]",
                                title="[cyan]Hyphen CLI[/cyan]",
                                expand=False,
                            )
                        )
                        return
                except requests.exceptions.RequestException:
                    sha256_path = None  # Dosya yoksa devam et ama taşıma

                # Yeni sürümü oku
                with open(new_meta_path) as m:
                    new_info = yaml.safe_load(m)
                new_version = new_info.get("version", "0.0.0")

                # Sürüm karşılaştırması
                if is_newer_version(new_version, old_version):
                    console.print(
                        Panel(
                            f"[bold cyan]Update available:[/bold cyan] {old_version} -> {new_version}\nUpdating...",
                            title="[cyan]Hyphen CLI[/cyan]",
                            expand=False,
                        )
                    )

                    # --- Dosya Taşıma İşlemleri (Eski dosyaların üzerine yazma) ---
                    if platform.system() == "Windows":
                        dest_dir = f"{hyphenctl_path}\\lib\\{package}"
                        move_commands = [
                            f"Move-Item -Force '{new_meta_path}' '{dest_dir}\\meta.hyphen';",
                            f"Move-Item -Force '{os.path.join(temp_dir, new_info.get('file'))}' '{dest_dir}\\{new_info.get('file')}';",
                        ]
                        if sha256_path:
                            move_commands.append(
                                f"Move-Item -Force '{sha256_path}' '{dest_dir}\\{sha256_path.split(chr(92))[-1]}';"
                            )

                        ps_script = " ".join(move_commands)
                        subprocess.run(
                            [
                                "powershell",
                                "-Command",
                                f"Start-Process powershell -Verb RunAs -ArgumentList '-Command {ps_script}'",
                            ]
                        )
                    else:
                        has_sudo, has_doas = False, False
                        try:
                            r = subprocess.run(
                                ["sudo", "--version"],
                                stdout=subprocess.DEVNULL,
                                stderr=subprocess.DEVNULL,
                            )
                            if r.returncode == 0:
                                has_sudo = True
                        except:
                            pass
                        try:
                            r = subprocess.run(
                                ["doas", "--version"],
                                stdout=subprocess.DEVNULL,
                                stderr=subprocess.DEVNULL,
                            )
                            if r.returncode == 0:
                                has_doas = True
                        except:
                            pass

                        priv = "sudo" if has_sudo else ("doas" if has_doas else None)

                        if priv:
                            subprocess.run(
                                [
                                    priv,
                                    "mv",
                                    "-f",
                                    new_meta_path,
                                    f"{lib_dir}/meta.hyphen",
                                ]
                            )
                            subprocess.run(
                                [
                                    priv,
                                    "mv",
                                    "-f",
                                    os.path.join(temp_dir, new_info.get("file")),
                                    f"{lib_dir}/{new_info.get('file')}",
                                ]
                            )
                            if sha256_path:
                                subprocess.run(
                                    [
                                        priv,
                                        "mv",
                                        "-f",
                                        sha256_path,
                                        f"{lib_dir}/{sha256_path.split('/')[-1]}",
                                    ]
                                )
                        else:
                            try:
                                subprocess.run(
                                    [
                                        "mv",
                                        "-f",
                                        new_meta_path,
                                        f"{lib_dir}/meta.hyphen",
                                    ]
                                )
                                subprocess.run(
                                    [
                                        "mv",
                                        "-f",
                                        os.path.join(temp_dir, new_info.get("file")),
                                        f"{lib_dir}/{new_info.get('file')}",
                                    ]
                                )
                                if sha256_path:
                                    subprocess.run(
                                        [
                                            "mv",
                                            "-f",
                                            sha256_path,
                                            f"{lib_dir}/{sha256_path.split('/')[-1]}",
                                        ]
                                    )
                            except Exception as e:
                                console.print(
                                    Panel(
                                        f"[bold red]ERROR[/bold red] Permission denied. Install sudo or doas.",
                                        title="[cyan]Hyphen CLI[/cyan]",
                                        expand=False,
                                    )
                                )
                                shutil.rmtree(temp_dir)
                                return

                    shutil.rmtree(temp_dir)
                    time_passed = dt.now() - started_time
                    seconds = time_passed.total_seconds()
                    console.print(
                        Panel(
                            f"[bold green]Updated:[/bold green] {package} to v{new_version}\nCompleted in {int(seconds // 60)}m {int(seconds % 60)}s",
                            title="[cyan]Hyphen CLI[/cyan]",
                            expand=False,
                        )
                    )
                else:
                    shutil.rmtree(temp_dir)
                    console.print(
                        Panel(
                            f"[bold cyan]Already up to date:[/bold cyan] {package} (v{old_version})",
                            title="[cyan]Hyphen CLI[/cyan]",
                            expand=False,
                        )
                    )

                break  # Paket bulundu ve kontrol edildi, döngüyü kır

            except Exception as e:
                console.print(
                    Panel(
                        f"[bold red]An error occurred during update[/bold red]\n{e}",
                        title="[cyan]Hyphen CLI[/cyan]",
                        expand=False,
                    )
                )
                if "temp_dir" in locals() and os.path.exists(temp_dir):
                    shutil.rmtree(temp_dir)
                break

    if not found:
        console.print(
            Panel(
                f"[bold red]Package not found in databases:[/bold red] {package}",
                title="[cyan]Hyphen CLI[/cyan]",
                expand=False,
            )
        )


