[Unit]
Description=Hyphen Agent for Linux - WebUI Service
After=network.target

[Service]
Type=simple

User=PLACEHOLDER_USER
WorkingDirectory=PLACEHOLDER_WD

Environment=PYTHONUNBUFFERED=1

ExecStart=PLACEHOLDER_EXEC

Restart=on-failure
RestartSec=3

KillSignal=SIGTERM
TimeoutStopSec=10

StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target